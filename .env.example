# Memoir 环境变量配置文件
# 复制此文件为 .env 并修改配置

# ─── 端口配置 ──────────────────────────────────────────────
# Ollama 端口（如果 11434 被占用，修改此值）
OLLAMA_PORT=11435

# WebUI 端口
WEBUI_PORT=5000

# ─── 路径配置 ──────────────────────────────────────────────
# 照片目录（宿主机路径）
PHOTO_DIR=./photos

# 数据目录（宿主机路径）
DATA_DIR=./data

# 配置文件路径
CONFIG_FILE=./config.json

# ─── 认证配置 ──────────────────────────────────────────────
# API 密钥（可选）
API_KEY=

# 设备 MAC 地址（可选）
DEVICE_MAC=

# ─── 时区配置 ──────────────────────────────────────────────
TZ=Asia/Shanghai
